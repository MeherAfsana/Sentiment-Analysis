import pandas as pd
import numpy as np
from sklearn.model_selection import train_test_split
from sklearn.preprocessing import LabelEncoder
from tensorflow.keras.preprocessing.text import Tokenizer
from tensorflow.keras.preprocessing.sequence import pad_sequences
from tensorflow.keras.layers import Embedding, Dense, Input, Dropout, Conv1D, GlobalMaxPooling1D, GRU, Concatenate
from tensorflow.keras.models import Model
from tensorflow.keras.utils import to_categorical
from sklearn.ensemble import RandomForestClassifier
from sklearn.metrics import classification_report, confusion_matrix
import matplotlib.pyplot as plt
import seaborn as sns

# Load your cleaned Excel file
data = pd.read_excel(r"C:\Users\PC\OneDrive\Desktop\Group-5\Advanced(grp-5)\Merge_All_Tag_V2.1.xlsx")  # Specify the correct Excel file path

# Drop rows with missing values (NaN) in 'comments' and 'tags' columns
data = data.dropna(subset=['Comments', 'Sentiments'])

# Assuming your Excel has two columns: 'comments' and 'tags' where 'comments' contains text data and 'tags' contains labels (Positive, Negative, Neutral)
X = data['Comments']
y = data['Sentiments']

# Encode labels
label_encoder = LabelEncoder()
y_encoded = label_encoder.fit_transform(y)

# Split the data into training and testing sets
X_train, X_test, y_train, y_test = train_test_split(X, y_encoded, test_size=0.2, random_state=42)

# Tokenize and pad your text data
max_sequence_length = 100  # Adjust as needed
tokenizer = Tokenizer()
tokenizer.fit_on_texts(X_train)  # Fit the tokenizer on the training data
X_train_sequences = tokenizer.texts_to_sequences(X_train)  # Tokenize the training data
X_test_sequences = tokenizer.texts_to_sequences(X_test)  # Tokenize the test data
X_train_padded = pad_sequences(X_train_sequences, maxlen=max_sequence_length, padding='post', truncating='post')
X_test_padded = pad_sequences(X_test_sequences, maxlen=max_sequence_length, padding='post', truncating='post')

# One-hot encode the labels for both training and test data
y_train_onehot = to_categorical(y_train, num_classes=len(label_encoder.classes_))
y_test_onehot = to_categorical(y_test, num_classes=len(label_encoder.classes_))

# Create an embedding layer
vocab_size = len(tokenizer.word_index) + 1
embedding_dim = 100  # Adjust as needed
embedding_layer = Embedding(input_dim=vocab_size, output_dim=embedding_dim, input_length=max_sequence_length)

# Build the GRU model
input_layer_gru = Input(shape=(max_sequence_length,))
embedding_gru = embedding_layer(input_layer_gru)
gru = GRU(64)(embedding_gru)
dense1_gru = Dense(128, activation='relu')(gru)
dropout_gru = Dropout(0.5)(dense1_gru)
output_layer_gru = Dense(len(label_encoder.classes_), activation='softmax')(dropout_gru)

# Compile the GRU model
model_gru = Model(inputs=input_layer_gru, outputs=output_layer_gru)
model_gru.compile(optimizer='adam', loss='categorical_crossentropy', metrics=['accuracy'])

# Train the GRU model
model_gru.fit(X_train_padded, y_train_onehot, validation_split=0.2, epochs=100, batch_size=32)

# Build the CNN model
input_layer_cnn = Input(shape=(max_sequence_length,))
embedding_cnn = embedding_layer(input_layer_cnn)
conv1 = Conv1D(128, 3, activation='relu')(embedding_cnn)
maxpool1 = GlobalMaxPooling1D()(conv1)
conv2 = Conv1D(128, 4, activation='relu')(embedding_cnn)
maxpool2 = GlobalMaxPooling1D()(conv2)
concat = Concatenate(axis=-1)([maxpool1, maxpool2])
dense1_cnn = Dense(128, activation='relu')(concat)
dropout_cnn = Dropout(0.5)(dense1_cnn)
output_layer_cnn = Dense(len(label_encoder.classes_), activation='softmax')(dropout_cnn)

# Compile the CNN model
model_cnn = Model(inputs=input_layer_cnn, outputs=output_layer_cnn)
model_cnn.compile(optimizer='adam', loss='categorical_crossentropy', metrics=['accuracy'])

import numpy as np
import pandas as pd
from sklearn.feature_extraction.text import TfidfVectorizer
from sklearn.model_selection import train_test_split
from sklearn.ensemble import RandomForestClassifier
from sklearn.metrics import classification_report, confusion_matrix
import matplotlib.pyplot as plt
from sklearn.preprocessing import LabelEncoder
import seaborn as sns

# Load your cleaned and preprocessed data
file_path = r"C:\Users\PC\OneDrive\Desktop\Group-5\Advanced(grp-5)\Merge_All_Tag_V2.1.xlsx"  # Replace with the actual file path
data = pd.read_excel(file_path)

# Reduce the dataset size for faster training (adjust as needed)
data = data.sample(frac=0.1, random_state=42)

# Split the data into features (X) and labels (y)
X = data['Comments'].astype(str)
y = data['Sentiments']

# TF-IDF Vectorization
tfidf_vectorizer = TfidfVectorizer(ngram_range=(1, 3), lowercase=True, max_features=1000)
X_tfidf = tfidf_vectorizer.fit_transform(X)

# Split the data into training and test sets
X_train, X_test, y_train, y_test = train_test_split(X_tfidf, y, test_size=0.2, random_state=42)

# Create and train the Random Forest model
rf_model = RandomForestClassifier(n_estimators=100, random_state=42)
rf_model.fit(X_train, y_train)

# Get the predicted labels
y_pred = rf_model.predict(X_test)

# Create the classification report
classification_rep = classification_report(y_test, y_pred)
print(f'Classification Report:\n{classification_rep}')

# Create the confusion matrix
confusion = confusion_matrix(y_test, y_pred)
print(f'Confusion Matrix:\n{confusion}')

# Plot the confusion matrix as a heatmap
plt.figure(figsize=(8, 6))
sns.heatmap(confusion, annot=True, fmt='d', cmap='Blues')
plt.xlabel('Predicted')
plt.ylabel('True')
plt.title('Confusion Matrix')
plt.show()
import numpy as np
import pandas as pd
from sklearn.feature_extraction.text import TfidfVectorizer
from sklearn.model_selection import train_test_split
from sklearn.ensemble import RandomForestClassifier
from sklearn.metrics import roc_curve, auc
import matplotlib.pyplot as plt
from sklearn.preprocessing import LabelEncoder

# Load your cleaned and preprocessed data
file_path = "C:\\Users\\PC\\OneDrive\\Desktop\\Group-5\\Merge_All_Tag_V2.xlsx"  # Replace with the actual file path
data = pd.read_excel(file_path)

# Reduce the dataset size for faster training (adjust as needed)
data = data.sample(frac=0.1, random_state=42)

# Split the data into features (X) and labels (y)
X = data['Comments'].astype(str)
y = data['Sentiments']

# TF-IDF Vectorization
tfidf_vectorizer = TfidfVectorizer(ngram_range=(1, 3), lowercase=True, max_features=1000)
X_tfidf = tfidf_vectorizer.fit_transform(X)

# Split the data into training and test sets
X_train, X_test, y_train, y_test = train_test_split(X_tfidf, y, test_size=0.2, random_state=42)

# Create and train the Random Forest model
rf_model = RandomForestClassifier(n_estimators=100, random_state=42)
rf_model.fit(X_train, y_train)

# Get predicted probabilities for each class
y_prob = rf_model.predict_proba(X_test)

# Compute ROC curve for each class
fpr = dict()
tpr = dict()
roc_auc = dict()
n_classes = len(y.unique())

for i in range(n_classes):
    fpr[i], tpr[i], _ = roc_curve(y_test == i, y_prob[:, i])
    roc_auc[i] = auc(fpr[i], tpr[i])

# Plot ROC curve for each class
plt.figure(figsize=(8, 6))
colors = ['b', 'g', 'r', 'c', 'm', 'y', 'k']
for i, color in zip(range(n_classes), colors):
    plt.plot(fpr[i], tpr[i], color=color, lw=2, label=f'ROC class {i} (area = {roc_auc[i]:.2f})')

plt.plot([0, 1], [0, 1], 'k--', lw=2)
plt.xlim([0.0, 1.0])
plt.ylim([0.0, 1.05])
plt.xlabel('False Positive Rate')
plt.ylabel('True Positive Rate')
plt.title('Receiver Operating Characteristic')
plt.legend(loc='lower right')
plt.show()
